build() {
  echo im build 2>&1 | tee "${FUNCNAME[1]}"

}

check() {
  echo im check 2>&1 | tee "${FUNCNAME[1]}"
}

package() {
  echo im package 2>&1 | tee "${FUNCNAME[1]}"

}
