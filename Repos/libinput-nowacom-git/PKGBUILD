pkgname=libinput-nowacom-git
pkgver=1.31.0.r42.g356c498f
pkgrel=1
pkgdesc="Input device management and event handling library - compiled without support for wacom tablets"
url="https://gitlab.freedesktop.org/libinput/libinput"
arch=(x86_64)
license=(MIT)
depends=('mtdev' 'libevdev' 'glibc')
# upstream doesn't recommend building docs
makedepends=('git' 'meson' 'wayland-protocols' 'check') # 'doxygen' 'graphviz' 'python-sphinx' 'python-recommonmark'
checkdepends=('python-pytest')
optdepends=('gtk4: libinput debug-gui'
            'python-pyudev: libinput measure'
            'python-libevdev: libinput measure'
            'python-yaml: used by various tools')
provides=(libinput)
conflicts=(libinput)
source=(git+https://gitlab.freedesktop.org/libinput/libinput)
sha256sums=('SKIP')

pkgver() {
  cd libinput
  git describe --long | sed 's/^foo-//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

___options=( --auto-features=auto --wipe --clearcache  \
--auto-features=auto \
-D udev-dir="/usr/lib/udev" \
-D libwacom="false" \
-D autoload-plugins="false" \
-D coverity="false" \
-D debug-gui="false" \
-D install-tests="false" \
-D internal-event-debugging="false" \
-D lua-plugins="auto" \
-D mtdev="false" \
-D tests="false" \
-D zshcompletiondir="/etc/completions.d/zsh" \
-D documentation="false" \
-D libwacom="false"  --reconfigure   # -Db_lto=true -Db_lto_mode=thin -Dc_std=gnu2y -Dcpp_std=gnu++26
	)
build() {
 build libinput "${___options[@]}" 
  # Print config
 PKG_CONFIG_LIBDIR="" PKG_CONFIG_PATH="" meson configure build   "${_options[@]}" 

  # PKG_CONFIG_LIBDIR="" PKG_CONFIG_PATH="" meson compile pkgname should cd to the package being built "${pkgname}"
 PKG_CONFIG_LIBDIR="" PKG_CONFIG_PATH="" meson compile -C build
}

check() {
 PKG_CONFIG_LIBDIR="" PKG_CONFIG_PATH="" meson test -C build --print-errorlogs
}

package() {
 PKG_CONFIG_LIBDIR="" PKG_CONFIG_PATH="" meson introspect  build --install-plan 2>&1 | tee install-plan
 PKG_CONFIG_LIBDIR="" PKG_CONFIG_PATH="" meson install -C build --only-changed --no-rebuild --destdir  "$pkgdir"

  install -Dvm644 libinput/COPYING \
    "$pkgdir/usr/share/licenses/libinput/LICENSE"
}



